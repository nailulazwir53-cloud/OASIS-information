# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_API_TIMEOUT=30000

# Authentication
NEXT_PUBLIC_AUTH_ENDPOINT=/api/auth
NEXT_PUBLIC_JWT_STORAGE_KEY=oasis_jwt

# Feature Flags
NEXT_PUBLIC_ENABLE_SEARCH=true
NEXT_PUBLIC_ENABLE_PAPERS=true
NEXT_PUBLIC_ENABLE_KNOWLEDGE_GRAPH=true
NEXT_PUBLIC_ENABLE_COPILOT=true
NEXT_PUBLIC_ENABLE_GAPS=true

# Application
NEXT_PUBLIC_APP_NAME=OASIS
NEXT_PUBLIC_APP_DESCRIPTION=Research Intelligence Platform
NEXT_PUBLIC_APP_LOGO_URL=/logo.png

# Analytics (optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SENTRY_DSN=

# Environment
NODE_ENV=development
